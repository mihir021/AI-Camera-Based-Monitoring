# =========================
# Media / Data
# =========================
# Ignore local test videos and large data processing outputs
*.mp4
*.avi
*.mov
*.mkv
ai/data/processed/
ai/data/raw/
!ai/data/.gitkeep

# Ignore zip files (dataset exports, temp downloads)
*.zip

# Ignore temp extraction folders
ai/TEmp/

# Ignore extracted training/validation images and labels (generated by prepare_data.py)
# These can be huge (thousands of .jpg/.txt files) and should not be in git
ai/data/images/train/
ai/data/images/val/
ai/data/labels/train/
ai/data/labels/val/
ai/data/raw_videos/
ai/data/*.jpg

# Keep .gitkeep files so folder structure stays in git
!ai/data/images/train/.gitkeep
!ai/data/images/val/.gitkeep
!ai/data/labels/train/.gitkeep
!ai/data/labels/val/.gitkeep

# Ignore YOLO training run output folders (logs, charts, intermediate weights)
# Only the final best.pt gets copied to ai/models/ manually after training
ai/runs/
runs/

# Note: Trained models in ai/models/ (e.g., classroom_v1.pt) ARE tracked in git
# so teammates can download and use them without re-training.
# Uncomment below ONLY if model files become too large for git (>100MB):
# *.pt
# *.onnx
